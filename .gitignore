# IDE and editor files
/.vscode
/rhis-builder-bootstrap-init.code-workspace

# Claude Code local settings
.claude/

# Locally installed Ansible collections
.ansible/

# Ansible inventory and variable files containing environment-specific data
/host_vars/*
/group_vars/*
inventory

# Ansible logs - may contain decrypted variable values at higher verbosity
ansible.log
*.log.txt

# Vault and secrets files - never commit these
vault*.yml
*-vault.yml
*.vault
*vault*

# Contributor-specific vault naming conventions
*.parmstrong.ca.*
*.example.ca.*

# SSH keys and certificates
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub

# Temporary and generated files
*.retry
*.pyc
__pycache__/
.pytest_cache/

# Molecule test artifacts
molecule/.cache/
